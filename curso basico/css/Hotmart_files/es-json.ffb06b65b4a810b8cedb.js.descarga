(window.webpackJsonp=window.webpackJsonp||[]).push([[14],{1178:function(e){e.exports=JSON.parse('{"checkout_beta":{"powered":"Desarrollado por Hotmart","redirect":"Redirigiendo","step_one":"Datos personales","step_one_button":"Próximo paso","step_two":"Pago","step_two_button":"Efectuar pago","step_three":"¡Gracias!","security":"Compra 100 % Segura","secure_icons":{"secure_buy":{"information":"Compra","text":"Segura"},"product_reviewd":{"information":"Producto 100%","text":"Revisado"},"protected_data":{"information":"Datos 100%","text":"Protegidos"}},"country":"Cambiar país","change_country_search":"Escribe el país...","country_current":"País actual","name_label":"Tu nombre completo","name_placeholder":"Introduce tu nombre completo","email_label":"Tu email","email_confirmation_label":"Confirma tu email","email_confirmation_placeholder":"Introduce nuevamente tu email","email_placeholder":"Introduce el email que recibirá el producto","instagram_username_label":"Tu nombre de usuario en Instagram","instagram_username_placeholder":"Ej.: nombredeusuario","cpf_label":"Registro de Persona Física","cpf_placeholder":"Sólo números","document_label":"Registro de Persona Física/Registro de Persona Jurídica","document_label_generic":"Documento de identidad","document_placeholder_simple":"Registro de Persona Física/Registro de Persona Jurídica","document_placeholder_simple_generic":"Doc. de identidad","document_placeholder":"Ingresa tu número de documento","document_placeholder_generic":"Introduce tu doc. de identidad","cpf_tip":"El número de Registro de Persona Física o Jurídica es necesario para aprobar tu <strong>compra con seguridad</strong>","cpf_secure_tip":"Por exigencia del Banco Central, tu solicitud de pago ha de informar tu CPF/CNPJ.","phone_label":"Teléfono celular","phone_label_ddd":"Código de área","phone_placeholder_ddd":"XX","phone_placeholder_number":"XXXXXXXXX","cep_label":"Código Postal","cep_label_generic":"Código Postal","cep_placeholder":"Introduce aquí tu Código Postal","cep_placeholder_generic":"Introduce tu cód. postal","cep_forget":"No sé mi Código Postal","state_label":"Estado provincial","state_placeholder":"¿Cuál?","city_label":"Ciudad","city_placeholder":"¿Dónde vives?","district_label":"Barrio","district_placeholder":"Introduce aquí tu barrio","address_label":"Dirección","address_placeholder":"¿Cuál es tu dirección?","manual_transfer":"Transferencia Bancaria","number_label":"Número","number_placeholder":"XXX","complement_label":"Complemento","complement_placeholder":"XXX","region_label":"Región","region_placeholder":"Selecciona tu región","international_address":{"address_line1":"Dirección línea 1","address_line2":"Dirección línea 2 (opcional)","placeholder":{"address_line2":"Apto. 101"}},"tax":{"australia":{"tax_info_label":"¿Estás comprando como empresa y tienes Australian business number (ABN)?","tax_info_label_field":"Añadir Australian business number (ABN)","placeholder_label":"ABN","valid_message":"¡Tu ABN ha sido validado con éxito!","invalid_message":"No se ha podido validar tu ABN","cannot_apply_discount":"Algo ha salido mal. El ABN que informaste no tiene un registro GST y, por eso, no es posible realizar la compra con exención de este impuesto. Para finalizar tu compra, verifica el estatus de tu registro e inténtalo de nuevo, o elimina tu ABN.","info_message":"Si estás comprando como empresa y tienes Australian business number (ABN) con registro válido para Goods and Services Tax (GTS), tu compra está exenta de este impuesto. Asegúrate de que los números de tu ABN estén correctos y de tener un registro activo para GTS.","show":"Estoy comprando como empresa","hide":"No estoy comprando como empresa","summary":{"tax_label":"GST","info_message":"Goods and Services Tax (GST)"}},"canada":{"tax_info_label":"¿Estás comprando como empresa y posees un GST number?","tax_info_label_field":"Tu GST number","placeholder_label":"GST number","valid_message":"¡Tu GST number ha sido validado con éxito!","invalid_message":"No ha sido posible validar tu GST number","cannot_apply_discount":"¡Algo ha salido mal! El documento de empresa que has informado no posee registro GST, por eso, no es posible realizar la compra con exención de impuesto. Para finalizar tu compra, verifica el estatus de tu registro e inténtalo de nuevo, o elimina tu documento de empresa.","info_message":"Si estás en Canadá, comprando como una empresa, y posees un GST number, tu compra está exenta de impuestos. Verifica si has informado tu documento correctamente y si el número es válido.","show":"Estoy comprando como empresa","hide":"No estoy comprando como una empresa","summary":{"tax_label":"GST","info_message":"Goods and Services Tax (GST)"},"region":{"QC":{"tax_info_label":"¿Estás comprando como empresa y posees un GST / QST number?","tax_info_label_field":"Tu número QST","placeholder_label":"Número QST","valid_message":"¡Tu número QST ha sido validado con éxito!","invalid_message":"No se ha podido validar tu número QST","cannot_apply_discount":"¡Algo ha salido mal! El documento de empresa que has informado no posee registro QST, por eso, no es posible realizar la compra con exención de impuesto. Para finalizar tu compra, verifica el estatus de tu registro e inténtalo de nuevo, o elimina tu documento de empresa.","info_message":"Si estás en Quebec, comprando como una empresa, y posees un número QST, tu compra está exenta de impuestos. Verifica si has informado tu documento correctamente y si el número QST es válido.","show":"Añadir GST / QST Number","hide":"Eliminar QST / GST Number","summary":{"tax_label":"QST","info_message":"Quebec Sales Tax (QST)"}},"ON":{"tax_info_label":"¿Estás comprando como una empresa y posees un GST/HST number?","tax_info_label_field":"Tu GST/HST number","placeholder_label":"GST/HST number","valid_message":"¡Tu GST/HST number ha sido validado con éxito!","invalid_message":"No ha sido posible validar tu GST/HST number","cannot_apply_discount":"¡Algo ha salido mal! El documento de empr