der":"000","payment_details":"Payment Details","payment_token_label":"Payment code","payment_token_placeholder":"Enter the code you\'ve received by email","phone_label":"Phone number","phone_number_placeholder":"Enter your cellphone number","phone_number_placeholder_brasil":"(31) 9 8765-4321","postal_code_label":"Zip Code","postal_code_placeholder":"Enter your ZIP code here","region_helper":"We use this information to collect the right taxes for your location","region_label":"Region","region_placeholder":"Select your region","select_placeholder":"Select","shopper_data_consent":"I accept to receive product communications via email","state_label":"State","state_placeholder":"Which one?","terms_of_service_agreement":{"label":"I\'m aware that Hotmart is processing {AUTHOR_NAME}\'s service request and I agree with the {PURCHASE_TERMS} and confirm that I have read and understood the {PRIVACY_POLICY}.","purchase_terms":"Terms of Purchase","privacy_policy":"Privacy Policy","privacy_policy_url":"https://www.hotmart.com/legal/en/data-privacy-policy"},"validation":{"cpf":"The document you entered is not valid","email":"Invalid email address","mobile":"Check your phone number","required":"The {0} field is required.","virtualCardCaixa":"This number is not from a virtual card "},"vat_number_label":"Add Intra-Community VAT","vat_number_placeholder":"Enter number here","vat_number_validation_name":"Intra-Community VAT"},"general":{"all_rights_reserved":"All rights reserved ","apply":"Apply","author":"Author","back":"Go back","close":"Close","congratulations":"Congratulations","contact":"Contact:","continue":"Continue","date_and_time":"Date & time","email":"Email","error":"Error","event":"Event","got_it":"I got it","hi":"Hello","label_ref":"REF.","link_faq":"https://atendimento.hotmart.com.br/hc/en-us/requests/new","link_help_central":"https://atendimento.hotmart.com.br/hc/pt-br/articles/360014492431-Como-comprar-um-produto-pela-Hotmart-","lot":"Batch","name":"Name","need_help":"Need any help?","online":"Online","pay_cash":"One-time payment","payment_trouble":"Problems with the Payment","place":"Location","quantity":"Quantity","remove":"Delete","secure_purchase":"100% Safe Purchase","show_more_payment_methods":"Show more payment methods","skip_to_main":"Skip to main content","start_chat":"Talk to Customer Support","string":"{0}","switch_card":"Update card","try_again":"Try again","unrecognized_error":"Unknown error","until":"to","update":"Update","vat":"VAT"},"installments":{"disabled_when_debit_card":"This is a debit card. If you want to pay for your purchase in installments, enter your credit card information.","label":"{0} payments of {1}","label_installment_interest_rate":"*Installments with a {0} monthly fee","label_installment_interest_generic":"*The installment amount has an additional fee.","label_on_billet_installment":"or in {0} installments of {1} with boletos (bank payment slips) ","label_on_credit_card":"or {0} payments of {1} on credit card","label_on_credit_card__without_interest_fee":"or in {0} installments of {1} on your credit card","label_on_credit_card_with_interest_fee":"or {0} payments of {1} on credit card","label_with_interest_fee":"{0} payments of {1}","label_without_interest_fee":"{0} x of {1} interest-free installments","number_installments":"{0} installments","one_time_payment":"One-time payment","options":"Select the number of installments","price_per_month":"{0} / {1} mo.","show_less_installments":"Show less payment options","show_more_installments":"Show more payment options","title":"Installment plan options "},"login":{"collaborator_login_message":"You\'re accessing this feature using <b>{0}</b>, but you don\'t have permission to use this account. Log in with your account to make payments with your Hotmart Account. ","login_by":"Login via","login_continue":"Log in to continue:","login_hotmart":"Log In","login_sparkle":"Log in with Sparkle","sparkle":{"instructions":{"0":"Open Hotmart Sparkle on your smartphone","1":"Click on the QRCode button in the upper-right corner","2":"Read the QRCode on the side"}}},"order_term":{"access_help_central":"access our Help Center","hotmart_capital_letters":"HOTMART","hotmart_ebanx_capital_letters":"HOTMART*EBANX","text":{"0":"In case of any problems or doubts about the purchase, such as payment options, access to the product, refund, and support, please","1":"This product was created by {0} For matters relative to the contents of this product, please contact the producer on the email:","2":"This purchase will be shown in your credit card statement as made in the store {0} - {1}. However, it\'s important to highlight that this is only how the purchase will be shown in the card statement or invoice because the digital product purchased was not created by HOTMART, which bears no responsibility for its content, functionality, characteristics, offer, and advertising;","3":"If the purchase of the Digital Product was made through Smart Installments, according to the offer and policies created under the responsibility of the Digital Producer, you\'re hereby aware that the not payment of any installment will result in blocking the access to the product purchased. Besides, the defaulting Buyer may be stopped from making new purchases of digital products registered at the Hotmart Platform. ","4":"If this Digital Product is being offered in Free Trial Period, which represents a free usage period. The free usage period (Free Trial Period) will start when indicated by the Digital Producer and aims to allow people interested in the product to have a taste of the digital content in the abovementioned period.","5":"It is important to highlight that if you do not expressly cancel the Free Trial Period at the end od the free usage period, the Digital Producer responsible for the product will automatically start charging the payment concerning the subscription of the Digital Product, whose purchase will be ruled by this Terms of Purchase. ","6":"The producer of the product (Digital Producer/Seller) is solely and exclusively responsible for the digital product, in all legal and financial aspects. Any administrative or legal questions that come from the content of the purchased product, its characteristics, functionalities, offer, and advertisement should be done directly to the Producer through the email stated above or any other form of contact made available by the seller;","7":"By completing the purchase, you agree and accept in whole and without restrictions the Terms of Use and Privacy Policies of the Hotmart Platform, whose complete version can be accessed through the following link <a href=\\"https://www.hotmart.com/en/tos\\" target=\\"_blank\\">link</a>. Therefore, an attentive reading of the aforementioned documents is recommended;","8":"There is a warranty period of {0} days, ensured by the Producer, to request the cancellation of the purchase in the case of any defect/inconsitency of the product;","9":"The cancellation deadline mentioned above will start from the moment the purchase is completed. Therefore, you, the buyer, are responsible for immediately verifying if the access to the digital product works properly. Accordingly, if there are technical problems, duly proved by the buyer, to access the content purchased, the deadline for the cancellation will be suspended until the problem is solved, when it will resume counting from when it started. ","10":"The deadline for the delivery of the digital product can vary according to the payment method used, for example: Credit Card up to 24h, Wire Transfer up to 8h. ","11":"Hotmart is a digital products distribution platform and holds no employment relationship or of any other nature other than the service delivery of technology and digital distribution to the vendors. Therefore, it is important to emphasize that Hotmart is not legally and/or financially liable for the digital product purchased, once its content, functionality, quality, offer and, advertisement, are of sole responsibility of the Digital Producer who created it and made it available on the platform;","12":"Any additional information about the product must be obtained by the buyer straight from the seller (Digital Producer) after the purchase. The buyer will receive an email address where to contact the seller.","13":"In the case of a refund, the buyer will be refunded via wire transfer or credit card chargeback, depending on the payment method used at the time of the purchase. The refund can take up to thirty days to be completed in the case of a wire transfer and, from 30 to 60 days when via credit card chargeback.","14":"Your contact information, such as email, phone number, etc., may be sent to the seller e/or the seller\'s promotion partner. ","15":"This purchase and/or related affiliate commissions may be canceled if the purchase is found to have been carried out by an Affiliate using his own affiliate link.","16":"This purchase may be revoked and/or the affiliate commissions canceled if the Buyer\'s information is not completely filled in with truthful information about the Buyer.  ","17":"If the purchase is being made by a buyer that has made more than one refund request, the purchase may not be approved.","18":"Completing a purchase confirms the buyer\'s understanding and agreement with our Terms of Purchase.","19":"Refund requests involve the return of the total amount of the purchase and are never partial. This applies to all products made available at the Hotmart Platform by Digital Producers. ","20":"The purchase of the DIGITAL PRODUCT has been made by means of Smart Installments, in accordance with the offer and policies created under the responsibilities of the PRODUCER. Therefore, the BUYER is aware that by not paying any portion of the payments will result in their access to the DIGITAL PRODUCT being blocked. In addition to this, the BUYER may be prevented from making future purchases of DIGITAL PRODUCTS registered on the Hotmart platform. ","21":"With 3x 4x Oney, you can pay for your purchase in 3, 4, 6, 10 or 12 installments with your bank card, from a value of € 90 and up to € 2,500 (a minimum installment of € 20, the values ​​and conditions available may vary depending on the circumstances). All charges will be made periodically to your card. Please note that the first payment will be made at the time of purchase. Valid for VISA or Mastercard, debit or credit cards, with an expiration date greater than the duration of the selected financing modality. For example, if you apply for financing for six months, your card\'s expiration date cannot be less than six months. We do not accept prepaid, virtual, or American Express cards. Only applicable to individuals, of legal age, living in Spain. 3x 4x Oney is a payment method that allows purchase in installments offered by Oney Servicios Financieros EFC, a financial institution registered and supervised by the Bank of Spain under number 8814. You can find more information about 3x 4x Oney <a href = \' https://www.oney.es/aviso-legal/informacion-legal-3x4xoney \'target =\' _ blank \'> here </a>. For any questions related to deferred payment, contact Oney at the following email cliente3x4x@Oney.es"},"title":"Terms of Purchase"},"payment":{"resend_token":"Resend code","security_step":"Security step","token_field_label":"We\'ve sent an email to <b>{0}</b> with a code. Enter it here please:"},"payment_button":{"description":"Proceed with purchase of {0} using {1}"},"payment_data":{"section_title":"Payment method details"},"payment_methods":{"billet":{"document_field_tip":"As determined by the Brazilian Central Bank, your boleto (bank payment slip) must contain your CPF/CNPJ. ","instructions":{"access":{"body":"The boleto (bank payment slip) expires in <b>2 business days</b>. Make the payment until the due date and guarantee your access to the product.","header":"Pay until the due date"},"due_date":{"body":"Payments by boleto (bank payment slip) take <b>up to 3 calendar days</b> to be cleared.","header":"Wait for payment confirmation"}},"instructions_title":"Please pay attention to the details:","name":"Boleto (Bank Payment Slip)","payment_button":"Buy now"},"billet_installments":{"instructions":{"recurrence":{"body":"Pay monthly payment slips that we will send by email without using your credit card limit.","header":"Receive one bank payment slip per installment "}},"instructions_title":"Information on installment payment with bank payment slips:","name":"Installment Payment with Bank Payment Slips","payment_button":"Buy now","term":"I understand that <b>monthly bank payment slips</b> will be sent <b> and must be paid until the last installment</b>, regardless of the length of the product purchased.","term_validation":"Required term"},"cash_payment":{"baloto":{"instructions":{"cash":{"body":"Baloto is only available for <b>payments in full.</b>","header":"One-time payment"},"confirmation":{"body":"The payment will be confirmed in up to 72 hours.","header":"Please wait for payment confirmation"},"due_date":{"body":"Don\'t forget that the voucher expires in 3 days.","header":"Pay until the due date"},"establishments":{"body":"Make the payment at a Baloto store of your choice.","header":"Approved establishments"}},"name":"Baloto","payment_button":"Issue Baloto"},"cupon_de_pago":{"instructions":{"cash":{"body":"Cupón de Pago is only available for <b>payments in full.</b>","header":"One-time payment"},"confirmation":{"body":"Payment confirmation will take 12 to 72 hours.","header":"Please wait for payment confirmation"},"establishments":{"body":"Go to any of these establishments to pay for your invoice: PagoFacil, RapiPago, CobroExpress PampaPagos, BaproPagos, PagoListo, ChubutPagos, Provincia Pagos, Formopagos, ProntoPago and Ripsa. You have up to 3 calendar days to make the payment.","header":"Approved establishments"},"print":{"body":"Depending on the establishment you choose, the barcode and/or reference code may be requested. Therefore it is recommended that you print the invoice or present it on your mobile phone.","header":"Print the coupon"}},"name":"Cupón de Pago","payment_button":"Issue Cupón de Pago"},"multibanco":{"instructions":{"cash":{"body":"Multibanco is only available for <b>payments in full.</b>","header":"One-time payment"},"due_date":{"body":"Pay attention to the due date on the invoice. It can be paid in any ATM or Home banking service.","header":"Pay until the due date"}},"name":"Multibanco","payment_button":"Buy now"},"oxxo":{"instructions":{"cash":{"body":"With OXXO, you can only make <b>cash payments.</b> Go to an OXXO store and tell the cashier the boleta number.","header":"Payment"},"confirmation":{"body":"The payment will be confirmed in up to three business days.","header":"Please wait for payment confirmation"}},"name":"Oxxo","payment_button":"Issue Oxxo"},"pago_efectivo":{"instructions":{"cash":{"body":"PagoEfectivo is only available for <b>payments in full.</b>","header":"One-time payment"},"confirmation":{"body":"When the transaction is confirmed, you\'ll get a purchase receipt. The payment is confirmed in 12 to 72 hours.","header":"Please wait for payment confirmation"},"due_date":{"body":"You choose if you want to pay cash in a physical establishment or via Home Banking. The voucher expires in 3 calendar days.","header":"Pay until the due date"}},"name":"PagoEfectivo","payment_button":"Issue PagoEfectivo"},"payment_button":"Buy now","sencillito":{"instructions":{"cash":{"body":"Sencillito is only available for <b>payments in full.</b>","header":"One-time payment"},"confirmation":{"body":"When the transaction is confirmed, you\'ll be given a receipt. The payment is confirmed between 12 to 72 hours.","header":"Please wait for payment confirmation"},"due_date":{"body":"Bring the invoice to one of the Sencillito affiliate stores and pay cash or with a pre-paid card. Invoice expires in: 3 calendar days","header":"Pay until the due date"}},"name":"Sencillito","payment_button":"Issue Sencillito "}},"credit_card":{"name":"Credit Card","payment_button":"Buy now"},"direct_bank_transfer":{"klarna":{"instructions":{"fast":{"body":"Your transfer is made right away and payment confirmation is instant.*","header":"Immediate confirmation"},"safe":{"body":"Make a secure payment with an online bank transfer <b>Pay Now / SOFORT</b> from Klarna.","header":"100% Secure"},"simple":{"body":"Just choose your bank, authenticate your account and make the online transfer.","header":"Simple and no registration"}},"name":"Online Transfer"},"payment_button":"Buy now"},"direct_debit":{"bacs":{"name":"Bank debit (BACS)","payment_button":"Buy now"},"name":"Bank Debit","payment_button":"Buy now","pse":{"name":"Bank debit (PSE)","payment_button":"Buy now"},"safety_pay":{"bill_name":"This purchase will appear on your statement as: <b>SafetyPay Brasil</b>","instructions":{"debit":{"body":"You will be redirected to a secure page for payments via bank transfer.","header":"One-time payment"},"safe":{"body":"For your security, you will have a 20-minute window to enter your information as requested.","header":"Safe transfer"}},"instructions_title":"Available banks","name":"Bank Debit","payment_button":"Buy now"},"sepa":{"name":"Online Transfer","payment_button":"Buy now"},"spei":{"instructions":{"confirmation":{"body":"SPEI payments are confirmed in real time.","header":"Immediate"},"due_date":{"body":"<b>Important:</b> The payment slip via SPEI is valid for 3 days. After 3 days, it wil not be possible to pay the payment slip and you will need to generate another one.","header":"Pay until the due date"},"payment":{"body":"With the issued payment slip, access your bank\'s internet banking system and make the transfer using the payment details you received.","header":"Payment"},"possibility":{"body":"SPEI allows you to make <b>one-time payments</b> and electronic transfers through their internet banking.","header":"Options"}},"instructions_title":"How to pay with SPEI?","name":"Transfer via SPEI","payment_button":"Generate payment slip"}},"fake_debit_card":{"name":"Debit card","payment_button":"Buy now"},"financed_billet":{"instructions":{"installments":{"body":"After a quick credit rating assessment, find out in how many installments you can pay for your purchase","header":"Choose the number of installments"},"parcel":{"body":"Apply for financing in a simple and safe way","header":"Pay for your purchase in installments using bank payment slips"},"payment":{"body":"Pay your installments with bank payment slips or PIX. You choose!","header":"Pay with bank payment slips or PIX"}},"instructions_title":"Parcelex Financing. Check out the details: ","name":"Parcelex","payment_button":"Check your credit rating"},"financed_installment":{"disclaimer":"Subject to approval from Oney Servicios Financieros EFC, SAU","first_installment":"Amount you\'ll pay now: <b>{0} €</b>","header":"Finance with","info":"By financing in <b>{0} monthly payments</b> you\'ll pay <b>{1}</b> of the total price of the purchase","instructions":{"fast":{"body":"With just an official ID, you can have credit approved instantly.* ","header":"Fast and simple"},"parcel":{"body":"You can divide into 3, 4, 6, 10, or 12 monthly installments and pay them with your bank card.  ","header":"Divide your expenses"},"your_way":{"body":"Charges are made monthly on your bank card without you having to do anything.","header":"Pay at your pace"}},"instructions_title":"Parcelex Financing. Check out the details: ","name":"Financed payment","payment_button":"Go to the payment site"},"google_pay":{"instructions":{"cards":{"body":"Google Pay accepts the following cards <b>{cardList}</b>.","header":"Cards accepted"},"payment":{"body":"One-time payment or in installments by credit card.","header":"Payment"}},"instructions_title":"Click on the button below to be redirected to Google Pay and pay attention to the details:","name":"Google Pay"},"hybrid":{"card_pix":{"instructions":