ase. Please, enter a card that was issued in the same country as your order. ","region_not_available":"It\'s not possible to make a subscription sale for your region. "},"footer":{"label_access_help_central":"I need help filling out this screen","label_contact_seller":"Contact","term":{"0":"I understand that Hotmart is processing this order in the name of {0} and I agree to the","1":"and I hereby confirm that I have read and understand the ","2":"https://www.hotmart.com/legal/en/data-privacy-policy","3":"Privacy Policy"}},"forms":{"US":{"region_label":"State","region_placeholder":"Select your state"},"accept_email_suggestion":"Accept email suggestion: {0}","address_label":"Address","address_line1_label":"Address","address_line1_placeholder":"Street and house number","address_line2_help":"E.g.: Apartment B2, second floor.","address_line2_label":"Address line 2 (optional)","address_line2_placeholder":"Apartment, suite, etc.","address_placeholder":"What is your address?","after_purchase":{"data_notice":"Fill in your details to issue the receipt","save_button":"Send"},"bacs_compliance_term_label":"I confirm the account is in my name and I am the only signatory required to authorize the Direct Debit on this account.","bacs_compliance_term_name":"compliance term","bacs_deduction_term_label":"I agree that the above amount will be deducted from my bank account.","bacs_deduction_term_name":"Deduction term","bank_account_name_label":"Bank Account Holder Name","bank_account_name_placeholder":"Enter the name","bank_account_number_label":"Bank Account Number","bank_account_number_placeholder":"Enter the number","bank_account_sort_code_label":"Sort Code","bank_account_sort_code_placeholder":"Enter the code","bank_label":"Bank","city_label":"City","city_placeholder":"Where do you live?","complement_label":"Additional address information (optional)","complement_placeholder":"Apartment / unit / building / floor","credit_card":{"card_cvv_label":"CVV","card_cvv_placeholder":"CVV","car