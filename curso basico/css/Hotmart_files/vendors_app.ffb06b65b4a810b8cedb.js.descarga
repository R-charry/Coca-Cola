     overflow: hidden;\n      position: fixed;\n      color: #797979;\n    }\n    .hotpay3DS__iframe-container--popup {\n      width: 95%;\n      height:500px;\n      overflow: hidden;\n      visibility: visible;\n      top: 20px;\n      left: 50%;\n      z-index: 9999999;\n      transform: translateX(-50%);\n      box-shadow: 0 2px 4px 0 rgba(0, 0, 0, .5);\n      resize: both;\n      border-radius: 8px;\n      border: 1px solid #797979;\n      display: flex;\n      flex-direction: column;\n    }\n    @keyframes loading {\n      0% {\n        transform: rotate(0deg);\n      }\n      100% {\n        transform: rotate(360deg);\n      }\n    }\n    @media all and (min-width: 361px) {\n      .hotpay3DS__iframe-container--popup {\n        height:600px;\n      }\n    }\n    @media all and (min-width: 651px) {\n      .hotpay3DS__iframe-container--popup {\n        width: 600px;\n        top: 30px;\n      }\n    }\n    .hotpay3DS__iframe-header {\n      border-bottom: 1px solid #797979;\n      background-color: #EDEDED;\n      max-height: 74px;\n      min-height: 43px;\n      display: flex;\n      justify-content: center;\n      flex-direction: column;\n      font-size: 12px;\n      padding-left: 10px;\n      font-weight: bold;\n      position: relative;\n      border-top-left-radius: inherit;\n      border-top-right-radius: inherit;\n    }\n    @media all and (min-width: 379px) {\n      .hotpay3DS__iframe-header {\n        align-items: center;\n      }\n    }\n    @media all and (min-width: 651px) {\n      .hotpay3DS__iframe-header {\n        font-size: 14px;\n      }\n    }\n    .hotpay3DS__iframe-subtitle {\n      align-self: center;\n      font-weight: normal;\n      display: block;\n      margin: 3px 0;\n    }\n    .hotpay3DS__iframe-body {\n      flex-grow: 1;\n    }\n    .hotpay3DS__iframe-footer {\n      border-top: 1px solid #797979;\n      background-color: #EDEDED;\n      border-bottom-left-radius: inherit;\n      border-bottom-right-radius: inherit;\n      font-size: 12px;\n    }\n    .hotpay3DS__iframe-footer a {\n      color: #0F85D1;\n      text-decoration: underline;\n    }\n    .hotpay3DS__help-header {\n      font-size: 11px;\n      margin: 10px;\n      position: relative;\n    }\n    @media all and (min-width: 651px) {\n      .hotpay3DS__help-header {\n        margin: 10px;\n      }\n      .hotpay3DS__bank-info {\n        max-width: 260px;\n      }\n    }\n    .hotpay3DS__help-btn-container {\n      font-size: 14px;\n      color: #0F85D1;\n    }\n    @media all and (min-width: 651px) {\n      .hotpay3DS__help-btn-container {\n        position: absolute;\n        top: 0;\n        right: 0;\n      }\n    }\n    .hotpay3DS__help-btn {\n      text-decoration: underline;\n      cursor: default;\n    }\n    .<%= it.expandedClass %> .hotpay3DS__help-btn {\n      display: none;\n    }\n    .hotpay3DS__help-btn--close {\n      text-decoration: underline;\n      display: none;\n      cursor: default;\n    }\n    .<%= it.expandedClass %> .hotpay3DS__help-btn--close {\n      display: inline;\n    }\n    .hotpay3DS__iframe-footer-reveal {\n      display: none;\n    }\n    .<%= it.expandedClass %> .hotpay3DS__iframe-footer-reveal {\n      display: block;\n    }\n    .hotpay3DS__help-content {\n      margin: 15px;\n      color: #000;\n    }\n    @media all and (min-width: 651px) {\n      .hotpay3DS__help-content {\n        margin: 25px;\n      }\n    }\n    .hotpay3DS__help-content p {\n      margin: 0 0 20px;\n    }\n    .hotpay3DS__iframe-container--loading::after {\n      content: \'\';\n      width: 40px;\n      height: 40px;\n      margin: -20px 0 0 -20px;\n      border-radius: 999999px;\n      top: 50%;\n      left: 50%;\n      border: 4px solid #CCCCCC88;\n      border-top-color: transparent;\n      border-bottom-color: transparent;\n      display: block;\n      position: absolute;\n      z-index: 2;\n      animation: loading .9s infinite linear;\n    }\n    .hotpay3DS__close-btn {\n      position: absolute;\n      right: 5p