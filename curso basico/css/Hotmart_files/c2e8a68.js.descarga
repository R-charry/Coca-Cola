ヘルプが必要ですか？","help-why":"なぜこれが表示されていますか？","help-why-text":"あなたの安全のため、銀行の発行者は本人確認を要求する場合があります。これが行われる理由はあなたのカードが不正に利用される事を防止するためです。","help-what-should-i-do":"次に何をすればいいのかわかりません。","help-what-should-i-do-text":"検証の実行方法にご質問がある場合、銀行の発行者にお問い合わせて、3DS安全認証方法を確認してください。.","help-know-more":"詳しくは、こちらです","help-cant-find":"私の質問は見つかりませんでした...","help-hide":"ヘルプを非表示にする","card-identification":"{cardNumber} **** **** ****"}}')},208:function(t,e,r){"use strict";var n=this&&this.__importDefault||function(t){return t&&t.__esModule?t:{default:t}};Object.defineProperty(e,"__esModule",{value:!0});var o=r(202),c=r(202),l=n(r(418)),d=n(r(419)),h=n(r(276)),f=n(r(421)),v=function(){function t(){this.mode="staging"}return t.prototype.get=function(t){return void 0===t&&(t={}),f.default.get(t,this.mode)},t.prototype.send=function(t){if(!t||"object"!=typeof t){var e="eventHub instance is required";return console.error(e),Promise.reject(e)}var r=c.validateRequiredFields(t,["system","entity","action","event"]),n=r.isValid,o=r.invalidField;if(!n){e="parameter "+o+" is required";return console.error(e),Promise.reject(e)}var l=new h.default({system:t.system,entity:t.entity,action:t.action,data_version:t.data_version||"1.0",event:t.event});return f.default.send(l,this.mode)},t.prototype.sendMetrify=function(t,element){if(!t||"object"!=typeof t){var e="eventHub instance is required";return console.error(e),Promise.reject(e)}var r=c.validateRequiredFields(t,["system","event"]);if(!r.isValid){e="parameter "+r.invalidField+" is required";return console.error(e),Promise.reject(e)}var n=c.validateRequiredFields(t.event,["group","name"]);if(!n.isValid){e="parameter "+n.invalidField+" is required inside event";return console.error(e),Promise.reject(e)}var h=new d.default({system:t.system,event:new l.default(t.event)});if(element&&o.isElement(element)){h.event.element={tag_name:element.tagName};for(var i=0;i<element.attributes.length;i++){var v=element.attributes[i];h.event.element[v.nodeName]=v.nodeValue}}return f.